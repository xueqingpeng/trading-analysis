# ── Authentication (pick one) ──────────────────────────

# Direct Anthropic API
ANTHROPIC_API_KEY=sk-ant-oat01-zdEf1OAX5bj2rgu3Q0bpf2JgQV64vI7Y
ANTHROPIC_BASE_URL= https://chat.coai.top/code
CLAUDE_MODEL=gpt-5.4

# Or Azure Foundry (all three required)
# ANTHROPIC_FOUNDRY_RESOURCE=your-resource
# ANTHROPIC_FOUNDRY_API_KEY=your-key
# CLAUDE_CODE_USE_FOUNDRY=1

# ── Model ─────────────────────────────────────────────
# Override default model (default: claude-sonnet-4-6)
# CLI --model flag takes priority over this.
# CLAUDE_MODEL=claude-sonnet-4-6

# ── Base URL (proxy / custom endpoint) ────────────────
# ANTHROPIC_BASE_URL=https://your-proxy.example.com

# ── Model aliases (haiku/sonnet/opus/subagent) ───────
# providers.py automatically pins all four aliases to the main CLAUDE_MODEL,
# so internal Claude CLI calls (compact/title/plan/subagent) use the same
# model as the top-level agent. This is what lets the proxy route every call
# to the same third-party endpoint without 404-ing on haiku/opus built-ins.
# ANTHROPIC_SMALL_FAST_MODEL is deprecated; we set ANTHROPIC_DEFAULT_HAIKU_MODEL
# (and _SONNET_ / _OPUS_ / CLAUDE_CODE_SUBAGENT_MODEL) automatically.
