# ── Authentication (pick one) ──────────────────────────

# Direct Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Or Azure Foundry (all three required)
# ANTHROPIC_FOUNDRY_RESOURCE=your-resource
# ANTHROPIC_FOUNDRY_API_KEY=your-key
# CLAUDE_CODE_USE_FOUNDRY=1

# ── Model ─────────────────────────────────────────────
# Override default model (default: claude-sonnet-4-6)
# CLI --model flag takes priority over this.
# CLAUDE_MODEL=claude-sonnet-4-6

# ── Base URL (proxy / custom endpoint) ────────────────
# ANTHROPIC_BASE_URL=https://your-proxy.example.com

# ── Small/fast model (proxy mode) ────────────────────
# Claude CLI internally calls haiku for title/compact.
# When using a proxy to OpenAI/Gemini, set this to a cheap model
# that your proxy supports, otherwise those calls will 404.
# ANTHROPIC_SMALL_FAST_MODEL=gpt-4.1-mini
